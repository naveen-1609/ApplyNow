rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function ownsExistingDocument() {
      return isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return isSignedIn() && request.resource.data.user_id == request.auth.uid;
    }

    // Users can only access their own profile (with admin access)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscriptionPlan', 'subscriptionStatus', 'subscriptionStartDate', 'subscriptionEndDate']);
      allow create: if isOwner(userId);
    }
    
    match /users/{userId}/notes/{noteId} {
      allow read, write: if isOwner(userId);
      allow read: if resource.data.shared == true;
    }
    
    match /users/{userId}/notes/{noteId}/versions/{versionId} {
      allow read, write: if isOwner(userId);
    }
    
    match /job_applications/{applicationId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }
    
    match /resumes/{resumeId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }
    
    match /cover_letters/{coverLetterId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }
    
    match /targets/{targetId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }
    
    match /schedules/{scheduleId} {
      allow read: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }
    
    match /subscription_transactions/{transactionId} {
      allow read, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isSignedIn() &&
        request.auth.uid == resource.data.userId &&
        request.auth.uid == request.resource.data.userId;
    }
    
    match /admin_users/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
