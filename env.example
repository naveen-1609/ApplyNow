# ApplyNow Environment Configuration
# Copy this file to .env and update with your actual values

# Firebase Environment Selection
# Set to "production" or "test". If omitted, production is used.
NEXT_PUBLIC_FIREBASE_ENV=production
FIREBASE_ENV=production

# Firebase Client Configuration
# You can keep using the shared values below, or define the environment-scoped
# variants such as NEXT_PUBLIC_FIREBASE_PRODUCTION_API_KEY and
# NEXT_PUBLIC_FIREBASE_TEST_API_KEY to keep prod/test fully isolated.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin Configuration
# For production/test isolation, prefer the scoped variants:
# FIREBASE_ADMIN_PRODUCTION_PROJECT_ID, FIREBASE_ADMIN_TEST_PROJECT_ID, etc.
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_STORAGE_BUCKET=your_project.appspot.com

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (Optional - if not set, prices will be created automatically)
# Get these from Stripe Dashboard → Products → Your Product → Price ID
STRIPE_PLUS_PRICE_ID=price_your_plus_price_id_here
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here
STRIPE_PLUS_PRODUCT_ID=prod_your_plus_product_id_here
STRIPE_PRO_PRODUCT_ID=prod_your_pro_product_id_here

# Application Configuration
APP_URL=https://appconsole.tech
NODE_ENV=production

# Monitoring Configuration (Optional)
GRAFANA_PASSWORD=your_grafana_password_here

# Database Configuration (if using external database)
DATABASE_URL=your_database_url_here

# Security Configuration
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here
